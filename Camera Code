# SETUP
OUT = "captures"          # name of the save folder
N_FRAMES = 5              # how many photos to take
WARMUP = 30               # how many frames to skip
os.makedirs(OUT)          # creates the captures/ folder

# FIND CAMERAS
devices = list(rs.context().query_devices())   # scans for cameras
if not devices:                                 # stops if none found
    raise RuntimeError("No RealSense cameras found")

# LOOP THROUGH EACH CAMERA
for dev in devices:
    serial = dev.get_info(rs.camera_info.serial_number)  # gets camera serial number
    label  = dev.get_info(rs.camera_info.name)           # gets camera name

# CONFIGURE STREAM
    cfg.enable_device(serial)                             # selects this camera
    cfg.enable_stream(rs.stream.color, 1280, 720, ...)   # sets resolution to 1280x720
    pipe.start(cfg)                                       # starts the camera

# WARMUP
    for _ in range(WARMUP):
        pipe.wait_for_frames()                            # skips 30 frames

# CAPTURE & SAVE
    for i in range(N_FRAMES):
        frames = pipe.wait_for_frames()                   # grabs a frame
        color  = np.asanyarray(frames.get_color_frame()  # converts to image array
        path   = os.path.join(OUT, f"{label}_{i}...")    # builds filename
        cv2.imwrite(path, color)                          # saves as PNG
        time.sleep(0.3)                                   # waits 0.3s before next frame

# STOP
    pipe.stop()                                           # stops the camera stream
